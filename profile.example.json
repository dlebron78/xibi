{
  "environment": "dev",
  "watch_topics": [
    {
      "query": "Puerto Rico tourism AI",
      "interval_minutes": 120,
      "max_results": 5
    },
    {
      "query": "software engineer remote jobs",
      "interval_minutes": 60,
      "max_results": 5
    }
  ],
  "watch_dirs": [
    {
      "path": "~/Documents/notes",
      "extensions": [
        "md",
        "txt"
      ],
      "interval_minutes": 60,
      "max_files": 10
    },
    {
      "path": "~/Desktop",
      "extensions": [
        "md"
      ],
      "interval_minutes": 120,
      "max_files": 5
    }
  ],
  "observation": {
    "baseline": "3x/day",
    "min_interval": "2h",
    "max_interval": "8h",
    "trigger_threshold": 5,
    "idle_skip": true,
    "cost_ceiling_daily": 5.00,
    "profiles": {}
  },
  "trust": {
    "fast_role_audit_interval": "weekly",
    "auto_promote_after_successes": 10
  },
  "channels": {
    "email": {
      "enabled": false,
      "send_enabled": false
    },
    "telegram": {
      "enabled": false
    }
  },
  "dev_overrides": {
    "dry_run_sends": true,
    "mock_channels": true,
    "log_level": "DEBUG",
    "test_recipient": "dev@example.com"
  }
}
