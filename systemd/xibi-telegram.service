[Unit]
Description=Xibi Telegram Adapter
After=network.target
Wants=network.target
OnFailure=xibi-caretaker-onfail.service

[Service]
Type=simple
WorkingDirectory=%h/xibi
EnvironmentFile=%h/.xibi/secrets.env
ExecStart=/usr/bin/python3 -m xibi --config %h/.xibi/config.json --workdir %h/.xibi telegram
Restart=on-failure
RestartSec=10
TimeoutStopSec=300
MemoryMax=256M
CPUQuota=50%
StandardOutput=journal
StandardError=journal
SyslogIdentifier=xibi-telegram

[Install]
WantedBy=default.target
